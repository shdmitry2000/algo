# Environment Configuration Template
# Copy this file to .env and fill in your credentials

# ============================================================================
# DATA PROVIDER SELECTION
# ============================================================================
# Choose which provider to use for fetching option chain data
# Options: yfinance | tradier | theta | schwab (stub for data; orders in Phase 3+)
# Default: yfinance (free, no credentials required)
DATA_PROVIDER=yfinance


# ============================================================================
# YFINANCE PROVIDER
# ============================================================================
# Yahoo Finance - Free, no credentials required
# Data: ~15 minute delay, good quality
# Best for: Development, testing, learning
# Setup: None needed!


# ============================================================================
# TRADIER PROVIDER
# ============================================================================
# Tradier.com - Real-time market data
# Get token: https://developer.tradier.com
# 
# For sandbox testing (recommended for development):
TRADIER_ACCESS_TOKEN=your_tradier_token_here
TRADIER_SANDBOX=true
#
# For production (real-time data):
# TRADIER_ACCESS_TOKEN=your_production_token_here
# TRADIER_SANDBOX=false


# ============================================================================
# THETA PROVIDER
# ============================================================================
# ThetaData - Professional-grade real-time data
# Get account: https://thetadata.com
# Requires: Paid subscription
#
THETA_USERNAME=your_theta_username
THETA_PASSWORD=your_theta_password

# ThetaData Bulk API Mode (PRO subscription only)
# Set to 'true' to enable fast bulk API (~2-5s per symbol, all expirations)
# Leave 'false' for FREE tier (per-strike mode, ~6min per symbol, 2 expirations)
# Bulk APIs: /v2/bulk_hist/option/quote, /v2/bulk_snapshot/option/quote
THETA_BULK_API=false


# ============================================================================
# PHASE 2 PERFORMANCE OPTIMIZATION
# ============================================================================
# Strike Filtering: Limit Phase 2 calculations to N strikes around ATM
# This speeds up strategy scans without affecting Phase 1 data gathering
# All data remains in cache; filtering only affects calculations
#
# MAX_STRIKES_ITM: Number of in-the-money strikes to calculate (below ATM)
# MAX_STRIKES_OTM: Number of out-of-the-money strikes to calculate (above ATM)
# Set to -1 for unlimited (calculate all strikes, slower but comprehensive)
#
# Examples:
#   MAX_STRIKES_ITM=25 MAX_STRIKES_OTM=25  (default: 50 total strikes, fast)
#   MAX_STRIKES_ITM=50 MAX_STRIKES_OTM=50  (100 total strikes, slower)
#   MAX_STRIKES_ITM=-1 MAX_STRIKES_OTM=-1  (unlimited, slowest)
MAX_STRIKES_ITM=25
MAX_STRIKES_OTM=25


# ============================================================================
# SCHWAB PROVIDER (Phase 3/4 - Order Execution)
# ============================================================================
# Charles Schwab - For placing orders in Phase 3
# Note: Not used for data gathering, only order execution
# Setup: OAuth flow (to be implemented in Phase 3)
#
# SCHWAB_APP_KEY=your_app_key
# SCHWAB_APP_SECRET=your_app_secret
# SCHWAB_ACCOUNT_ID=your_account_id


# ============================================================================
# IBKR PROVIDER (Optional - Stub Available)
# ============================================================================
# Interactive Brokers - Data + Order Execution
# Requires: IB Gateway or TWS running
# See: datagathering/providers/ibkr_provider_stub.py
#
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497          # 7497=live TWS, 7496=paper TWS, 4002=Gateway
# IBKR_CLIENT_ID=1


# ============================================================================
# REDIS CACHE
# ============================================================================
# Redis server configuration for caching option chains, signals, and history
# Development: from project root run `docker compose up -d` (see docker-compose.yml),
#   or install Redis locally (see SETUP_GUIDE.md). Defaults below match Compose.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379


# ============================================================================
# HISTORICAL DATA MODE (Legacy - for theta_stream.py testing)
# ============================================================================
# Used by theta_stream.py for testing without live streaming
# Options: STREAMING | HISTORICAL
DATA_GATHER_MODE=HISTORICAL

# Historical test parameters (if DATA_GATHER_MODE=HISTORICAL)
HIST_TEST_TICKER=AAPL
HIST_TEST_EXP=20240119
HIST_TEST_STRIKE=150
HIST_TEST_RIGHT=C


# ============================================================================
# PHASE 2 CONFIGURATION
# ============================================================================
# Phase 2 scan parameters (optional - defaults in code)
# Tick lists, fee_per_leg, spread caps, etc. are loaded from config/settings.yaml
# (copy config/settings.example.yaml to config/settings.yaml if missing)
# 
# PHASE2_FEE_PER_LEG=0.65           # Commission per leg
# PHASE2_INCLUDE_IMBALANCED=true    # Include imbalanced strategies
# PHASE2_MIN_DTE=7                  # Minimum days to expiration
# PHASE2_MAX_DTE=60                 # Maximum days to expiration


# ============================================================================
# PHASE 3 CONFIGURATION (To be implemented)
# ============================================================================
# Phase 3 order execution parameters
#
# PHASE3_MAX_POSITIONS=10           # Maximum concurrent positions
# PHASE3_POSITION_SIZE=1000         # Dollars per position
# PHASE3_MIN_ANNUAL_RETURN=50       # Minimum annual return % required
# PHASE3_ORDER_TYPE=LIMIT           # LIMIT | MARKET


# ============================================================================
# LOGGING
# ============================================================================
# Logging level for application
# Options: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO


# ============================================================================
# NOTES
# ============================================================================
#
# Quick Start:
# 1. Copy this file: cp .env.example .env
# 2. Choose a provider (yfinance works immediately)
# 3. Add credentials if using tradier/theta
# 4. Start Redis: docker compose up -d  (or native redis-server — SETUP_GUIDE.md)
# 5. Run: python cli/run_phase2_scan.py
#
# Provider Selection Guide:
# - Development: yfinance (free, no setup)
# - Testing: tradier with TRADIER_SANDBOX=true (realistic, free)
# - Production: theta or tradier production (real-time, paid)
# - Phase 3/4: schwab (order execution)
#
# Testing:
# - Test all: python tests/run_all_tests.py
# - Test providers: python tests/providers/test_all_providers.py
# - Live test: python tests/providers/test_live_providers.py --provider yfinance
#
# Documentation:
# - Main README: README.md
# - Provider Guide: PROVIDER_QUICKREF.md
# - Testing Guide: tests/providers/README.md
# - Templates: tests/providers/PROVIDER_TEMPLATES.md
#
